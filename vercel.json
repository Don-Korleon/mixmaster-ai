{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build:vercel",
  "installCommand": "npm install && npm install --prefix webapp",
  "framework": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/webhook/:path*", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 60
    }
  }
}
