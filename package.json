{
  "name": "mixmaster-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Telegram AI music remix bot + Mini App",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build:server && npm run build:webapp",
    "build:vercel": "npm run build:server && npm run build:webapp && node scripts/copy-webapp.mjs",
    "build:server": "tsc -p tsconfig.json",
    "build:webapp": "npm run build --prefix webapp",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "daily:winner": "node dist/jobs/daily-winner.js",
    "daily:winner:dev": "tsx src/jobs/daily-winner.ts",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "grammy": "^1.35.0",
    "multer": "^1.4.5-lts.1",
    "uuid": "^11.0.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
